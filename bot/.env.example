# Token del bot de Telegram (obtenido de @BotFather)
BOT_TOKEN=

# Clave privada Nostr del bot (nsec1...)
# Generarla con:
# node --input-type=module -e "import{generateSecretKey,nip19}from 'nostr-tools'; const sk=generateSecretKey(); console.log(nip19.nsecEncode(sk))"
BOT_NSEC=
